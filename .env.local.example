# Supabase — copy these from your project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service-role key — used ONLY in server-side scripts (never exposed to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: override the default basePath (/game)
# NEXT_PUBLIC_BASE_PATH=/game

# Admin panel — /game/admin
ADMIN_PASSWORD=your-admin-password-here

# Cloudflare — token needs Zone:Edit + Zone:Read permissions
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
